## DiskPart.cd - catalog description (single source of truth for all
## translatable strings).  CatComp/FlexCat-compatible.
##
## Generate the C header:   python3 support/gencat.py header DiskPart.cd ../src/diskpart_strings.h
## Make a translation tmpl:  python3 support/gencat.py ct DiskPart.cd deutsch.ct deutsch
## Compile a .catalog:        python3 support/gencat.py catalog DiskPart.cd deutsch.ct DiskPart.catalog
##
## RULES FOR EDITORS:
##   * Append new messages at the END of their section, never insert in the
##     middle - ids are positional and must stay stable for existing catalogs.
##   * Keep printf-style %-placeholders identical in translations.
##
#language english
#version 1
#name DiskPart
;
