;==========================================================================
; partview_diskcopy.c
;==========================================================================
MSG_DC_TITLE
Copy Whole Disk to Another Disk
;
MSG_DC_WARN_TITLE
Copy Whole Disk to Another Disk - WARNING
;
MSG_DC_WARN_BODY
This copies the ENTIRE disk block-for-block onto\nanother disk of your choosing.\n\nRDB, MBR, all partitions and filesystems on the\nDESTINATION disk will be permanently OVERWRITTEN.\n\nYou will be asked to pick the destination disk on\nthe next screen.\n\nContinue?
;
MSG_DC_SELF_BODY
Cannot copy a disk onto itself.\nPlease choose a different destination disk.
;
MSG_DC_OPEN_FAIL_FMT
Could not open destination disk:\n%s
;
MSG_DC_SIZE_MISMATCH_FMT
Destination disk (%s) is smaller than the\nsource disk (%s).\n\nChoose a destination disk at least as large as\nthe source.
;
MSG_DC_BLOCKSIZE_MISMATCH
Source and destination disks use different\nblock sizes and cannot be copied directly.
;
MSG_DC_DEVUNIT_FMT
%s unit %lu  (%s)
;
MSG_DC_CONFIRM_TITLE
Copy Whole Disk - FINAL WARNING
;
MSG_DC_CONFIRM_BODY_FMT
About to ERASE and overwrite:\n\n  %s\n\nwith the full contents of:\n\n  %s\n\nThis cannot be undone.  Are you absolutely sure?
;
MSG_DC_CONFIRM_GADGETS
Yes, copy|Cancel
;
MSG_DC_PROGRESS_TITLE_FMT
Copying to %s
;
MSG_DC_OK
Disk copy complete.\n\nReboot may be required for the new partition\nlayout on the destination disk to be picked up,\nif it was already mounted.
;
MSG_DC_CANCELLED
Copy cancelled.\n\nWARNING: the destination disk has been\npartially overwritten and is in an\ninconsistent state.
;
MSG_DC_FAILED_FMT
Copy failed:\n%s
;
;==========================================================================
; SHRINKINFO (minimum shrinkable size report)
;==========================================================================
MSG_SI_SCANNING_FMT
Scanning %s (%s) allocation bitmap...\n
;
MSG_SI_HEADER_FMT
\nShrink report for %s (%s):\n
;
MSG_SI_CURRENT_FMT
  Current size : %lu cylinders (%lu-%lu) = %s\n
;
MSG_SI_USED_FMT
  In use       : %lu of %lu blocks (%lu%%)\n
;
MSG_SI_HIGHEST_FMT
  Highest used : block %lu of %lu\n
;
MSG_SI_MIN_FMT
  Minimum size : %lu cylinders = %s  (HighCyl >= %lu)\n
;
MSG_SI_RECLAIM_FMT
  Reclaimable  : %lu cylinders = %s\n
;
MSG_SI_RECLAIM_NONE
  Reclaimable  : nothing - no room to shrink\n
;
MSG_SI_META_NOTE_FMT
  Note: movable FS metadata near block %lu excluded (a SHRINK would relocate it).\n
;
MSG_SI_SFS_DELETED_FMT
  Note: %lu blocks held by deleted (recycle-bin) files still count as used.\n
;
MSG_SI_FLUSH_CAVEAT
  Note: numbers reflect the state last flushed to disk.\n
;
MSG_SI_UNSUPPORTED_FMT
%s: SHRINKINFO supports FFS/OFS, SFS and PFS3 only (dostype 0x%08lx).\n
;
MSG_SI_FAIL_FMT
SHRINKINFO %s failed: %s\n
;
MSG_SI_NOT_FOUND_FMT
SHRINKINFO: no partition named "%s" on this disk.\n
;
MSG_SI_USAGE
Usage: SHRINKINFO <drive>   (report how far a partition could shrink)\n
;
MSG_SI_BM_READ_FMT
cannot read bitmap block %lu
;
MSG_SI_BM_BAD_FMT
bitmap block %lu is invalid - run the disk validator/doctor first
;
MSG_SI_PFS_SMALLIDX
PFS small-index layout (no MODE_SUPERINDEX) is not supported
;
